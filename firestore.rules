// ============================================================
//  Database Security Rules (Google Firestore)
//  Copy-paste ke:
//  console.firebase.google.com → project diana-website
//  → Firestore Database → tab Rules → Publish
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /photos/{docId} {
      allow read:   if true;
      allow create: if request.resource.data.keys().hasAll(['url','publicId','name','year','uploadedAt'])
                    && request.resource.data.year in ['2025','2026'];
      allow delete: if true;
    }
  }
}
